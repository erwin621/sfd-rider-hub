# ──────────────────────────────────────────────────────
# SFD Rider Hub — Environment Configuration
# Copy this file to .env and fill in your real values.
# NEVER commit .env to version control.
# ──────────────────────────────────────────────────────

# ── Server ──────────────────────────────────────────
NODE_ENV=development
PORT=3000

# ── Neon PostgreSQL ──────────────────────────────────
# Get this from: https://console.neon.tech
# Project → Connection Details → Connection string
# Format: postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require
DATABASE_URL=postgresql://your_user:your_password@ep-xxxx-xxxx.us-east-2.aws.neon.tech/sfd_rider_hub?sslmode=require

# ── Security ─────────────────────────────────────────
# Generate a random 64-char string: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=replace_with_a_long_random_secret_string_here

# ── CORS ─────────────────────────────────────────────
# Comma-separated list of allowed origins
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
